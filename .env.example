## Copy this file to .env and edit before running in production
# A long random hex string. Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-secret

# Controls whether session cookies are marked Secure. Use 'true' for HTTPS in production.
SESSION_COOKIE_SECURE=true

# If running behind a reverse proxy/ingress that terminates TLS, set TRUST_PROXY=1
TRUST_PROXY=1

# Default port inside container
PORT=3000

# NODE_ENV=production enables production behavior
NODE_ENV=production
